# ── API Server (Railway) ──────────────────────────────────────────────────────
# Provided automatically by Railway — do not set manually
PORT=8080

# PostgreSQL connection string — provisioned by Railway Postgres plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign JWT tokens — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string

# One-time seed endpoint secret — generate with: openssl rand -hex 16
# Used to call POST /api/seed to populate admin user, features, settings, prompts
# Remove or leave unset after seeding to disable the endpoint
SEED_SECRET=change_me_before_seeding

# ── Frontend (Vercel) ─────────────────────────────────────────────────────────
# Set in Vercel project settings → Environment Variables
# Point to your Railway API server URL (no trailing slash)
VITE_API_URL=https://your-api.up.railway.app
